# ── Firebase (cliente, públicas) ──────────────────────────────
NEXT_PUBLIC_FIREBASE_PROJECT_ID=project-x-xxx
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=project-x-xxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=project-x-xxx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456:web:abc123

# ── Server-only (NUNCA exponer en el cliente) ─────────────────
# JSON completo del service account en una sola línea
FIREBASE_ADMIN_SDK_KEY={"type":"service_account","project_id":"project-x-xxx",...}
